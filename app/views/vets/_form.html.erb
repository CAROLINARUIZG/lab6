<%= form_with(model: vet) do |f| %>
  <%= render 'shared/error_messages', object: vet %>

  <div class="mb-3">
    <%= f.label :first_name, "First Name", class: "form-label" %>
    <%= f.text_field :first_name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :last_name, "Last Name", class: "form-label" %>
    <%= f.text_field :last_name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :license_number, "License Number", class: "form-label" %>
    <%= f.text_field :license_number, class: "form-control" %>
  </div>

  <%= f.submit class: "btn btn-primary" %>
<% end %>