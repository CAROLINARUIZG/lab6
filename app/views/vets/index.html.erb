<h1 class="my-4">Veterinarios</h1>
<table class="table table-striped table-hover border shadow-sm">
  <thead class="table-dark">
    <tr>
      <th>Nombre Completo</th>
      <th>Email</th>
      <th>Especialización</th>
    </tr>
  </thead>
  <tbody>
    <% @vets.each do |vet| %>
      <tr>
        <td><%= link_to "Dr. #{vet.first_name} #{vet.last_name}", vet_path(vet), class: "fw-bold text-decoration-none" %></td>
        <td><%= vet.email %></td>
        <td><%= vet.specialization %></td>
      </tr>
    <% end %>
  </tbody>
</table>
