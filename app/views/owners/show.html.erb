<div class="card shadow">
  <div class="card-body">
    <h1><%= @owner.first_name %> <%= @owner.last_name %></h1>
    <p><strong>Email:</strong> <%= @owner.email %></p>
    <p><strong>Teléfono:</strong> <%= @owner.phone %></p>
    <p><strong>Dirección:</strong> <%= @owner.address %></p>

    <h3 class="mt-4">Mascotas de este dueño:</h3>
    <ul class="list-group">
      <% @owner.pets.each do |pet| %>
        <li class="list-group-item">
          <%= link_to pet.name, pet_path(pet) %> (<%= pet.species %>)
        </li>
      <% end %>
    </ul>
    <%= link_to 'Volver a la lista', owners_path, class: 'btn btn-secondary mt-3' %>
  </div>
</div>