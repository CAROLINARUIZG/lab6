<h1 class="my-4">Dueños</h1>
<table class="table table-striped table-hover border shadow-sm">
  <thead class="table-dark">
    <tr>
      <th>Nombre Completo</th>
      <th>Email</th>
      <th>Teléfono</th>
      <th>Mascotas</th>
    </tr>
  </thead>
  <tbody>
    <% @owners.each do |owner| %>
      <tr>
        <td><%= link_to "#{owner.first_name} #{owner.last_name}", owner_path(owner), class: "fw-bold text-decoration-none" %></td>
        <td><%= owner.email %></td>
        <td><%= owner.phone %></td>
        <td><span class="badge bg-secondary"><%= owner.pets.count %></span></td>
      </tr>
    <% end %>
  </tbody>
</table>