<%= form_with(model: [@appointment, treatment]) do |f| %>
  <%= render 'shared/error_messages', object: treatment %>

  <div class="mb-3">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_field :description, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :administered_at, "Date and Time", class: "form-label" %>
    <%= f.datetime_field :administered_at, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :notes, class: "form-label" %>
    <%= f.text_area :notes, class: "form-control", rows: 3 %>
  </div>

  <%= f.submit "Save Treatment", class: "btn btn-primary" %>
  <%= link_to "Cancel", appointment_path(@appointment), class: "btn btn-secondary" %>
<% end %>