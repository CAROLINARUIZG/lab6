<h1 class="my-4">Mascotas</h1>
<table class="table table-striped table-hover border shadow-sm">
  <thead class="table-dark">
    <tr>
      <th>Nombre</th>
      <th>Especie</th>
      <th>Raza</th>
      <th>Dueño</th>
      <th>Fecha de Nacimiento</th>
    </tr>
  </thead>
  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td><%= link_to pet.name, pet_path(pet), class: "fw-bold text-decoration-none" %></td>
        <td><%= pet.species %></td>
        <td><%= pet.breed %></td>
        <td><%= pet.owner.first_name %> <%= pet.owner.last_name %></td>
        <td><%= pet.birth_date.strftime("%B %d, %Y") %></td>
      </tr>
    <% end %>
  </tbody>
</table>